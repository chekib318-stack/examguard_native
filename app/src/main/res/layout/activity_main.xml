<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0D1117"
    android:layoutDirection="rtl">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#161B22"
        android:padding="14dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/ivLogo"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@mipmap/ic_launcher"
            android:layout_marginEnd="10dp"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="رصد الغش الإلكتروني"
                android:textColor="#FFFFFF"
                android:textSize="17sp"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="وزارة التربية التونسية"
                android:textColor="#D4AF37"
                android:textSize="12sp"/>
        </LinearLayout>

        <Button
            android:id="@+id/btnExit"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="خروج"
            android:textColor="#FF4444"
            android:backgroundTint="#221111"
            android:textSize="12sp"/>
    </LinearLayout>

    <!-- BT state warning -->
    <TextView
        android:id="@+id/tvBtState"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="10dp"
        android:text=""
        android:textColor="#FFA500"
        android:textSize="14sp"
        android:gravity="center"
        android:background="#221A00"
        android:visibility="gone"/>

    <!-- Stats bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="10dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="جارٍ المسح..."
            android:textColor="#4ADE80"
            android:textSize="13sp"/>

        <TextView
            android:id="@+id/tvCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0 جهاز"
            android:textColor="#888"
            android:textSize="13sp"
            android:layout_marginStart="8dp"/>

        <Button
            android:id="@+id/btnScan"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="⏹ إيقاف"
            android:textColor="#FFFFFF"
            android:backgroundTint="#1E7145"
            android:textSize="12sp"
            android:layout_marginStart="8dp"/>
    </LinearLayout>

    <!-- Instructions -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="اضغط على أي جهاز لتتبع إشارته وتحديد موقعه"
        android:textColor="#666"
        android:textSize="12sp"
        android:gravity="center"
        android:paddingBottom="6dp"/>

    <!-- Device list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:padding="8dp"/>

</LinearLayout>
