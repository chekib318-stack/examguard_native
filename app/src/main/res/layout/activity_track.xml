<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0D1117"
    android:layoutDirection="rtl">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#161B22"
        android:padding="12dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnTrackStop"
            android:layout_width="wrap_content"
            android:layout_height="34dp"
            android:text="← رجوع"
            android:textColor="#FFFFFF"
            android:backgroundTint="#333"
            android:textSize="12sp"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginHorizontal="10dp">

            <TextView
                android:id="@+id/tvTrackName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Device Name"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tvTrackMac"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MAC"
                android:textColor="#555"
                android:textSize="11sp"
                android:fontFamily="monospace"/>
        </LinearLayout>

        <Button
            android:id="@+id/btnMute"
            android:layout_width="wrap_content"
            android:layout_height="34dp"
            android:text="🔊 صوت"
            android:textColor="#FFFFFF"
            android:backgroundTint="#1A2A1A"
            android:textSize="11sp"/>
    </LinearLayout>

    <!-- Guide instruction -->
    <TextView
        android:id="@+id/tvGuide"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="ابدأ بالتحرك للعثور على الجهاز"
        android:textColor="#D4AF37"
        android:textSize="14sp"
        android:gravity="center"
        android:padding="10dp"
        android:background="#1A1600"/>

    <!-- BIG RSSI display -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="#161B22"
            android:padding="12dp"
            android:layout_marginEnd="6dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="قوة الإشارة"
                android:textColor="#666"
                android:textSize="12sp"/>

            <TextView
                android:id="@+id/tvTrackRssi"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="-100 dBm"
                android:textColor="#4488FF"
                android:textSize="26sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="#161B22"
            android:padding="12dp"
            android:layout_marginStart="6dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="المسافة"
                android:textColor="#666"
                android:textSize="12sp"/>

            <TextView
                android:id="@+id/tvTrackDist"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="— م"
                android:textColor="#FFFFFF"
                android:textSize="24sp"
                android:textStyle="bold"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Zone label -->
    <TextView
        android:id="@+id/tvTrackZone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🟢 بعيد"
        android:textColor="#33AA55"
        android:textSize="22sp"
        android:textStyle="bold"
        android:gravity="center"
        android:padding="8dp"/>

    <!-- Signal bar -->
    <ProgressBar
        android:id="@+id/pbTrackSignal"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="12dp"
        android:layout_marginHorizontal="16dp"
        android:max="100"
        android:progress="0"
        android:progressTint="#33AA55"
        android:progressBackgroundTint="#222"/>

    <!-- RSSI Chart -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="سجل الإشارة (dBm)"
        android:textColor="#666"
        android:textSize="12sp"
        android:gravity="center"
        android:paddingTop="12dp"/>

    <tn.gov.education.examguard.RssiChartView
        android:id="@+id/chartView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_margin="8dp"/>

    <!-- Status -->
    <TextView
        android:id="@+id/tvTrackStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="جارٍ التتبع..."
        android:textColor="#444"
        android:textSize="11sp"
        android:gravity="center"
        android:paddingBottom="8dp"/>

</LinearLayout>
